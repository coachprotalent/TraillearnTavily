# Reverse proxy HTTPS pour Traillearn Search (Nginx).
# Remplacez search.exemple.org par votre domaine (DNS A → IP de la VM).
# Certificat : sudo certbot --nginx -d search.exemple.org
# Le service écoute sur 127.0.0.1:8088 (BIND_HOST par défaut) ; gardez-le ainsi.
# Activez LOCAL_SEARCH_TOKEN côté service (le proxy chiffre mais n'authentifie pas).

server {
    listen 443 ssl;
    server_name search.exemple.org;

    ssl_certificate     /etc/letsencrypt/live/search.exemple.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/search.exemple.org/privkey.pem;

    location / {
        proxy_pass         http://127.0.0.1:8088;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;   # le scraping peut prendre quelques secondes
    }
}

server {
    listen 80;
    server_name search.exemple.org;
    return 301 https://$host$request_uri;
}
