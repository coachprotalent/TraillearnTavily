# NB : la clé secrète SearXNG n'est PAS ici. Elle s'écrit dans searxng/settings.yml
# au déploiement : sed -i "s/ultrasecretkey/$(openssl rand -hex 32)/" searxng/settings.yml
#
# Interface d'écoute du port hôte (mapping Docker).
#   127.0.0.1 = sécurisé, accessible seulement depuis la VM (défaut).
#   0.0.0.0   = exposé à d'autres machines (tests via navigateur distant).
# SI 0.0.0.0 : activer LOCAL_SEARCH_TOKEN ci-dessous + restreindre le port 8088
# via le pare-feu / NSG Azure aux IP autorisées.
BIND_HOST=127.0.0.1
# URL interne de SearXNG (réseau Docker)
SEARXNG_URL=http://searxng:8080
# Port d'écoute du service
SERVICE_PORT=8088
# Si défini, exige ce Bearer sur /search ; sinon auth ignorée.
# FORTEMENT recommandé si BIND_HOST=0.0.0.0. Générer : openssl rand -hex 24
LOCAL_SEARCH_TOKEN=
# Pages scrapées en parallèle par requête
SCRAPE_CONCURRENCY=5
# Timeout fetch par page (ms)
SCRAPE_FETCH_TIMEOUT_MS=15000
# Troncature du contenu extrait (caractères)
SCRAPE_MAX_CHARS=20000
# Tolérance certificats TLS invalides au scraping
SCRAPE_ALLOW_INSECURE_TLS=true
# (Optionnel) Surcharge/extension de la map pays->langue SearXNG, sans redéployer le code.
# Format : "cameroon=fr,nigeria=en,brazil=pt". Le nom du pays est de toute façon injecté
# dans les termes de la requête (vrai biais géo) ; la langue n'est qu'un bonus.
SEARCH_COUNTRY_LANGUAGE=
